# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# LLM Providers (Multi-Key Setup)
GROQ_API_KEY_1=your-groq-api-key-1
GROQ_API_KEY_2=your-groq-api-key-2
GROQ_API_KEY_3=your-groq-api-key-3
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENROUTER_API_KEY_1=your-openrouter-api-key-1
OPENROUTER_API_KEY_2=your-openrouter-api-key-2
OPENROUTER_API_KEY_3=your-openrouter-api-key-3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Storage Configuration
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_JSONL=jsonl-datasets

# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Clerk Authentication
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
