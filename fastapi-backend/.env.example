# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Cerebras API Keys (Get free keys at https://cloud.cerebras.ai)
# Option 1: Single key (limited to 2 concurrent requests)
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Option 2: Multiple keys for round-robin (recommended: 5 keys = 10 concurrent requests)
# Each key can handle 2 parallel requests. With 5 keys, you get 10x speedup!
CEREBRAS_API_KEY_1=your-first-key-here
CEREBRAS_API_KEY_2=your-second-key-here
CEREBRAS_API_KEY_3=your-third-key-here
CEREBRAS_API_KEY_4=your-fourth-key-here
CEREBRAS_API_KEY_5=your-fifth-key-here

# Storage Configuration
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_JSONL=jsonl-datasets

# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
