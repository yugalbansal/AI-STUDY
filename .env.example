# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Services API Keys
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Additional API Keys
VITE_ASSEMBLYAI_API_KEY=your_assemblyai_key_here
VITE_GOOGLE_AI_API_KEY=your_google_ai_key_here
VITE_HUGGINGFACE_API_KEY=your_huggingface_key_here

# IMPORTANT NOTES:
# 1. ElevenLabs API Key: Current key is missing permissions. Generate a new one with:
#    - text-to-speech permission
#    - voices_read permission
#
# 2. Gemini API Key: Current key seems to work but may have rate limits
#
# 3. Never commit your .env file to version control
