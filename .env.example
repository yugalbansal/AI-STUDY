# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Supabase Configuration
VITE_SUPABASE_URL=https://auth.yugal.site
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Services API Keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Additional API Keys
VITE_ASSEMBLYAI_API_KEY=your_assemblyai_key_here
VITE_GOOGLE_AI_API_KEY=your_google_ai_key_here
VITE_HUGGINGFACE_API_KEY=your_huggingface_key_here

# IMPORTANT NOTES:
# 1. OpenRouter API Key (NEW): Get your free API key from https://openrouter.ai/keys
#    - Used for chat responses with free models (Mistral, Llama 3, Hermes)
#    - Automatically selects the right model based on your prompt
#    - No rate limits on free models
#
# 2. Groq API Key: Get from https://console.groq.com/keys
#    - Used for voice agent (STT with Whisper, TTS with Orpheus)
#    - Fast and reliable for real-time voice
#
# 3. ElevenLabs API Key: Generate a new one with:
#    - text-to-speech permission
#    - voices_read permission
#
# 4. Gemini API Key: Legacy support (now using OpenRouter instead)
#
# 5. Never commit your .env file to version control
